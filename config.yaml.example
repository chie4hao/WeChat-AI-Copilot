# 你的微信昵称，导入聊天记录时自动识别哪条消息是你发的
my_name: "你的微信昵称"

gemini:
  api_key: "YOUR_GEMINI_API_KEY"
  model: "gemini-2.0-flash"
  candidate_count: 3
  temperature: 0.9
  stream: true   # true=流式（逐字显示），false=等待完整结果后显示

# Claude 配置（可选）：填写后自动切换为 Claude 提供商，Gemini 配置将被忽略
# 推荐模型：claude-opus-4-7（性能最强），claude-sonnet-4-6（更快更省）
# claude:
#   api_key: "YOUR_ANTHROPIC_API_KEY"
#   model: "claude-opus-4-7"
#   candidate_count: 3

server:
  port: 3000
  # 本地端上报的认证 token（本地端 config.yaml 的 vps.secret 要与这里一致）
  sync_secret: "your-secret-token"
  # 填写后自动启用 HTTPS（使用已有证书，无需 Nginx/Caddy）
  # certPath: /root/cert/example.com/fullchain.pem
  # keyPath:  /root/cert/example.com/privkey.pem
  # IP 白名单（可选，限制哪些 IP 可以访问）
  # allowedIPs:
  #   - "127.0.0.1"
  # Web Push 推送通知（可选）
  # 生成方法：npx web-push generate-vapid-keys
  # vapid_subject: "mailto:you@example.com"
  # vapid_public_key: "BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA"
  # vapid_private_key: "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 过滤名单：昵称包含以下任意关键词时，不触发 AI 生成（适合屏蔽通知类账号）
# skip_names:
#   - "美团"
#   - "麦当劳"
#   - "招商银行"

# 系统 prompt：写你的人设和回复要求
# 聊天记录由程序自动从数据库读取并拼入，不需要在这里写
prompt: |
  你是我的聊天参谋，帮我想回复思路。

  【关于我】
  （在这里填写你的基本信息，例如：年龄、职业、性格、爱好等）
  示例：28岁，互联网从业者，性格内敛，喜欢户外运动。

  【回复要求】
  - 用自然的方式给我分析当前对话的情况、建议方向和理由，不需要按固定格式，像朋友聊天一样说
  - 然后给出若干条候选回复，长短根据情况判断，不强制字数限制
  - 候选回复语气像正常人发消息，自然真实
  - 绝对不能油腻、不能堆感叹号
  - 如果当前对话不需要回复，直接说明原因和建议
