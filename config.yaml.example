gemini:
  api_key: "YOUR_GEMINI_API_KEY"
  model: "gemini-2.0-flash"
  candidate_count: 3
  temperature: 0.9
  stream: true   # true=流式（逐字显示），false=等待完整结果后显示

server:
  port: 3000
  # 填写后自动启用 HTTPS（使用已有证书，无需 Nginx/Caddy）
  # certPath: /root/cert/example.com/fullchain.pem
  # keyPath:  /root/cert/example.com/privkey.pem

# 系统 prompt：写你的人设和回复要求
# 聊天记录由程序自动从数据库读取并拼入，不需要在这里写
prompt: |
  你是我的聊天参谋，帮我想回复思路。

  【关于我】
  （在这里填写你的基本信息，例如：年龄、职业、性格、爱好等）
  示例：28岁，互联网从业者，性格内敛，喜欢户外运动。

  【回复要求】
  - 用自然的方式给我分析当前对话的情况、建议方向和理由，不需要按固定格式，像朋友聊天一样说
  - 然后给出若干条候选回复，长短根据情况判断，不强制字数限制
  - 候选回复语气像正常人发消息，自然真实
  - 绝对不能油腻、不能堆感叹号
  - 如果当前对话不需要回复，直接说明原因和建议
